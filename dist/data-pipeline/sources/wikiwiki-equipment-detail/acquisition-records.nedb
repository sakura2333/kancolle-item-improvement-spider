ution": "start2-name", "evidence": "method-text", "canonicalShipId": 103, "canonicalShipName": "千代田", "start2Ship": {"shipId": 103, "shipName": "千代田", "apiSortno": 50, "apiAftershipId": 105}}, {"rawName": "千歳", "shipId": 102, "shipName": "千歳", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 102, "canonicalShipName": "千歳", "start2Ship": {"shipId": 102, "shipName": "千歳", "apiSortno": 49, "apiAftershipId": 104}}]}, {"types": ["ship"], "availability": "current-or-summary", "rawText": "最上や伊勢・日向でもOKだが入手機会と燃費は劣る。", "links": [], "evidenceKind": "list-item", "shipReferences": [{"rawName": "伊勢", "shipId": 77, "shipName": "伊勢", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 77, "canonicalShipName": "伊勢", "start2Ship": {"shipId": 77, "shipName": "伊勢", "apiSortno": 3, "apiAftershipId": 82}}, {"rawName": "日向", "shipId": 87, "shipName": "日向", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 87, "canonicalShipName": "日向", "start2Ship": {"shipId": 87, "shipName": "日向", "apiSortno": 4, "apiAftershipId": 88}}, {"rawName": "最上", "shipId": 70, "shipName": "最上", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 70, "canonicalShipName": "最上", "start2Ship": {"shipId": 70, "shipName": "最上", "apiSortno": 51, "apiAftershipId": 73}}]}, {"types": ["development"], "availability": "current-or-summary", "rawText": "開発理論値は20/30/10/50だが、上位機種狙い（烈風や紫電改二を狙うレシピ20/30/10/90など）の副産物で狙う方が効率的だろう。", "links": [{"text": "開発理論値", "href": "https://wikiwiki.jp/kancolle/%E9%96%8B%E7%99%BA%E7%90%86%E8%AB%96%E5%80%A4#c05ca38c"}, {"text": "烈風", "href": "https://wikiwiki.jp/kancolle/%E8%A9%A6%E8%A3%BD%E7%83%88%E9%A2%A8%20%E5%BE%8C%E6%9C%9F%E5%9E%8B"}, {"text": "紫電改二", "href": "https://wikiwiki.jp/kancolle/%E7%B4%AB%E9%9B%BB%E6%94%B9%E4%BA%8C"}], "evidenceKind": "list-item", "context": "開発"}, {"types": ["development", "quest"], "availability": "current-or-summary", "rawText": "上位機種が揃った後も、工廠任務や装備改修の消費装備としての需要（下記参照）が続くので、ある程度在庫を確保しておきたい。", "links": [], "evidenceKind": "list-item", "context": "開発", "questReferences": [{"rawName": "上位機種が揃った後も、工廠任務や装備改修の消費装備としての需要（下記参照）が続くので、ある程度在庫を確保しておきたい。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}], "methodCount": 5, "unclassifiedEvidenceCount": 0, "issueCount": 0, "accepted": true, "coverageStatus": "parsed", "schemaVersion": 3, "resolvedShipIds": [70, 73, 77, 82, 87, 88, 102, 103, 104, 105, 121, 129, 130, 286, 287, 460], "resolvedQuestKeys": [], "referenceIssueCount": 1, "referenceSchemaVersion": 2, "rawEvidence": {"cacheKey": "wikiwiki.jp/kancolle/%E7%91%9E%E9%9B%B2.html", "rawPath": ".spider/local/source-cache/wikiwiki.jp/kancolle/%E7%91%9E%E9%9B%B2.html", "contentSha256": "1c323f902b298e5774d85accd890ec2ff199319b269e5b3514189fd7dda4b838", "fetchedAt": 1783531717, "validatedAt": 1783531717, "acquisitionSource": "external-browser-session-crawl"}, "fetchAttempts": [{"candidateSource": "raw-cache", "status": "ok", "url": "https://wikiwiki.jp/kancolle/%E7%91%9E%E9%9B%B2", "cachePath": "wikiwiki.jp/kancolle/%E7%91%9E%E9%9B%B2.html", "contentSha256": "1c323f902b298e5774d85accd890ec2ff199319b269e5b3514189fd7dda4b838"}]}
