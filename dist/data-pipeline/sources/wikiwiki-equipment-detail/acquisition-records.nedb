ink-text", "canonicalShipId": 891, "canonicalShipName": "Salmon", "start2Ship": {"shipId": 891, "shipName": "Salmon", "apiSortno": 491, "apiAftershipId": 897}, "linkTarget": "Salmon", "linkHref": "https://wikiwiki.jp/kancolle/Salmon"}]}, {"types": ["ship", "development", "improvement"], "availability": "current-or-summary", "rawText": "22号★無しから改修更新で入手する場合、22号電探18個、開発資材84個、改修資材46個が必要（★+6以降を確実化した場合）。", "links": [], "evidenceKind": "list-item", "context": "初期装備艦"}, {"types": ["ship", "improvement"], "availability": "current-or-summary", "rawText": "更新による入手は鳥海改二からの入手より大きくコストが嵩む。", "links": [], "evidenceKind": "list-item", "context": "初期装備艦", "shipReferences": [{"rawName": "鳥海改二", "shipId": 427, "shipName": "鳥海改二", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 427, "canonicalShipName": "鳥海改二", "start2Ship": {"shipId": 427, "shipName": "鳥海改二", "apiSortno": 227, "apiAftershipId": 0}}]}, {"types": ["ship", "improvement"], "availability": "current-or-summary", "rawText": "鳥海改二の消費が改装設計図=勲章x4=改修資材x16相当のため、増加するコストはかなり重いと言える。", "links": [], "evidenceKind": "list-item", "context": "初期装備艦", "shipReferences": [{"rawName": "鳥海改二", "shipId": 427, "shipName": "鳥海改二", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 427, "canonicalShipName": "鳥海改二", "start2Ship": {"shipId": 427, "shipName": "鳥海改二", "apiSortno": 227, "apiAftershipId": 0}}]}, {"types": ["ship", "improvement"], "availability": "current-or-summary", "rawText": "22号を18個集めるのも意外とハードルが高く、同装備が余っていてかつ上記コスト増を呑んででも鳥海改二牧場をしたくない人向けの選択肢と言える。", "links": [], "evidenceKind": "list-item", "context": "初期装備艦", "shipReferences": [{"rawName": "鳥海改二", "shipId": 427, "shipName": "鳥海改二", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 427, "canonicalShipName": "鳥海改二", "start2Ship": {"shipId": 427, "shipName": "鳥海改二", "apiSortno": 227, "apiAftershipId": 0}}]}, {"types": ["ship", "ranking"], "availability": "current-or-summary", "rawText": "島風の初期装備に22号電探がある。", "links": [], "evidenceKind": "list-item", "context": "初期装備艦", "shipReferences": [{"rawName": "島風", "shipId": 50, "shipName": "島風", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 50, "canonicalShipName": "島風", "start2Ship": {"shipId": 50, "shipName": "島風", "apiSortno": 10, "apiAftershipId": 229}}]}, {"types": ["ship", "ranking"], "availability": "current-or-summary", "rawText": "改修餌にする場合は、稀にドロップしたときは小まめに装備を回収しておくと良い。", "links": [], "evidenceKind": "list-item", "context": "初期装備艦"}, {"types": ["ship", "ranking"], "availability": "current-or-summary", "rawText": "戦果周回向けの3-2や3-4でそこそこドロップするため、常設ランカーであればそこまで集めるハードルは高くないという意見も見られる。", "links": [], "evidenceKind": "list-item", "context": "初期装備艦"}, {"types": ["ship", "development"], "availability": "current-or-summary", "rawText": "島風のドロップが当てにできない場合は22号の入手がかなり厳しい。", "links": [{"text": "Scamp", "href": "https://wikiwiki.jp/kancolle/Scamp"}, {"text": "Salmon", "href": "https://wikiwiki.jp/kancolle/Salmon"}], "evidenceKind": "list-item", "context": "初期装備艦", "shipReferences": [{"rawName": "Scamp", "shipId": 299, "shipName": "Scamp", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 299, "canonicalShipName": "Scamp", "start2Ship": {"shipId": 299, "shipName": "Scamp", "apiSortno": 493, "apiAftershipId": 715}, "linkTarget": "Scamp", "linkHref": "https://wikiwiki.jp/kancolle/Scamp"}, {"rawName": "Salmon", "shipId": 891, "shipName": "Salmon", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 891, "canonicalShipName": "Salmon", "start2Ship": {"shipId": 891, "shipName": "Salmon", "apiSortno": 491, "apiAftershipId": 897}, "linkTarget": "Salmon", "linkHref": "https://wikiwiki.jp/kancolle/Salmon"}, {"rawName": "島風", "shipId": 50, "shipName": "島風", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 