4%E8%A6%8B%E5%BC%B5%E5%93%A1"}, {"text": "三式爆雷投射機改", "href": "https://wikiwiki.jp/kancolle/%E4%B8%89%E5%BC%8F%E7%88%86%E9%9B%B7%E6%8A%95%E5%B0%84%E6%A9%9F%E6%94%B9"}, {"text": "二式爆雷", "href": "https://wikiwiki.jp/kancolle/%E4%BA%8C%E5%BC%8F%E7%88%86%E9%9B%B7"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "一般的な報酬選択をすれば、水雷戦隊 熟練見張員はこれまでに2つ、D型改三も2つ、三式爆雷投射機改は1つもないだろう。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "ranking", "event"], "availability": "current", "rawText": "一方、ここでD型改三を取る前提なら上述の任務でE27逆探を選択し、E27逆探を三本同時に運用可能。", "links": [{"text": "水雷戦隊 熟練見張員", "href": "https://wikiwiki.jp/kancolle/%E6%B0%B4%E9%9B%B7%E6%88%A6%E9%9A%8A%20%E7%86%9F%E7%B7%B4%E8%A6%8B%E5%BC%B5%E5%93%A1"}, {"text": "三式爆雷投射機改", "href": "https://wikiwiki.jp/kancolle/%E4%B8%89%E5%BC%8F%E7%88%86%E9%9B%B7%E6%8A%95%E5%B0%84%E6%A9%9F%E6%94%B9"}, {"text": "二式爆雷", "href": "https://wikiwiki.jp/kancolle/%E4%BA%8C%E5%BC%8F%E7%88%86%E9%9B%B7"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "一方、ここでD型改三を取る前提なら上述の任務でE27逆探を選択し、E27逆探を三本同時に運用可能。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "ranking", "event"], "availability": "current", "rawText": "もちろんD型改三を三本装備させても良い。", "links": [{"text": "水雷戦隊 熟練見張員", "href": "https://wikiwiki.jp/kancolle/%E6%B0%B4%E9%9B%B7%E6%88%A6%E9%9A%8A%20%E7%86%9F%E7%B7%B4%E8%A6%8B%E5%BC%B5%E5%93%A1"}, {"text": "三式爆雷投射機改", "href": "https://wikiwiki.jp/kancolle/%E4%B8%89%E5%BC%8F%E7%88%86%E9%9B%B7%E6%8A%95%E5%B0%84%E6%A9%9F%E6%94%B9"}, {"text": "二式爆雷", "href": "https://wikiwiki.jp/kancolle/%E4%BA%8C%E5%BC%8F%E7%88%86%E9%9B%B7"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "もちろんD型改三を三本装備させても良い。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "ranking", "event"], "availability": "current", "r