{"equipmentId": 146, "equipmentName": "洋上補給", "source": "wikiwiki-equipment-detail", "sourceUrl": "https://wikiwiki.jp/kancolle/%E6%B4%8B%E4%B8%8A%E8%A3%9C%E7%B5%A6", "pageEquipmentId": 146, "sectionHeading": "入手方法について", "evidenceScope": "acquisition-section", "developmentAvailable": false, "developmentResolution": {"status": "resolved", "method": "wikiwiki-equipment-infobox-notes", "marker": "開発不可", "rawText": "開発不可、改修不可、入手方法補強増設枠に装備可能"}, "currentMethodTypes": ["event", "purchase", "quest", "ship"], "historicalMethodTypes": [], "methods": [{"types": ["ship"], "availability": "current-or-summary", "rawText": "初期装備：速吸/改。", "links": [{"text": "速吸", "href": "https://wikiwiki.jp/kancolle/%E9%80%9F%E5%90%B8"}, {"text": "改", "href": "https://wikiwiki.jp/kancolle/%E9%80%9F%E5%90%B8%E6%94%B9"}], "evidenceKind": "list-item", "shipReferences": [{"rawName": "速吸", "shipId": 460, "shipName": "速吸", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 460, "canonicalShipName": "速吸", "start2Ship": {"shipId": 460, "shipName": "速吸", "apiSortno": 260, "apiAftershipId": 352}, "linkTarget": "速吸", "linkHref": "https://wikiwiki.jp/kancolle/%E9%80%9F%E5%90%B8"}, {"rawName": "速吸改", "shipId": 352, "shipName": "速吸改", "status": "resolved", "resolution": "start2-name", "evidence": "link-page", "canonicalShipId": 352, "canonicalShipName": "速吸改", "start2Ship": {"shipId": 352, "shipName": "速吸改", "apiSortno": 1432, "apiAftershipId": 0}, "linkText": "改", "linkHref": "https://wikiwiki.jp/kancolle/%E9%80%9F%E5%90%B8%E6%94%B9"}, {"rawName": "速吸改", "shipId": 352, "shipName": "速吸改", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 352, "canonicalShipName": "速吸改", "start2Ship": {"shipId": 352, "shipName": "速吸改", "apiSortno": 1432, "apiAftershipId": 0}}]}, {"types": ["purchase"], "availability": "current-or-summary", "rawText": "アイテム屋さんで2個セットを300ポイントで買える。ご利用は計画的に。", "links": [{"text": "アイテム屋さん", "href": "https://wikiwiki.jp/kancolle/%E3%82%A2%E3%82%A4%E3%83%86%E3%83%A0#a620050f"}], "evidenceKind": "list-item"}, {"types": ["quest"], "availability": "current-or-summary", "rawText": "任務『「洋上補給」物資の調達』報酬 (マンスリー)", "links": [{"text": "「洋上補給」物資の調達", "href": "https://wikiwiki.jp/kancolle/%E4%BB%BB%E5%8B%99#id-Fm3"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "任務『「洋上補給」物資の調達』報酬 (マンスリー)", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest"], "availability": "current-or-summary", "rawText": "三式弾、九一式徹甲弾、ドラム缶に加えて、艦隊への補給量としてはかなり多めの燃料750・弾薬750を要求される…が、前述の通り、洋上補給発動時に実際に補給される燃料と弾薬は母港からの天引きである。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "三式弾、九一式徹甲弾、ドラム缶に加えて、艦隊への補給量としてはかなり多めの燃料750・弾薬750を要求される…が、前述の通り、洋上補給発動時に実際に補給される燃料と弾薬は母港からの天引きである。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest"], "availability": "current-or-summary", "rawText": "任務で消費する燃料や弾薬は何に使われているのだろうか。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "任務で消費する燃料や弾薬は何に使われているのだろうか。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "event"], "availability": "current-or-summary", "rawText": "任務『強行輸送艦隊、抜錨！』報酬 (クォータリー)\n他、単発任務報酬・イベント報酬等", "links": [{"text": "強行輸送艦隊、抜錨！", "href": "https://wikiwiki.jp/kancolle/%E4%BB%BB%E5%8B%99#id-Bq3"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "任務『強行輸送艦隊、抜錨！』報酬 (クォータリー)\n他、単発任務報酬・イベント報酬等", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}], "methodCount": 6, "unclassifiedEvidenceCount": 0, "issueCount": 0, "accepted": true, "coverageStatus": "parsed", "schemaVersion": 3, "resolvedShipIds": [352, 460], "resolvedQuestKeys": [], "referenceIssueCount": 4, "referenceSchemaVersion": 2, "rawEvidence": {"cacheKey": "wikiwiki.jp/