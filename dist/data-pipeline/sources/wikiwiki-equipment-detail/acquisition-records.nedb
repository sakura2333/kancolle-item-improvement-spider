ship", "improvement"], "availability": "current-or-summary", "rawText": "零式水上偵察機からの改修更新。", "links": [{"text": "零式水上偵察機", "href": "https://wikiwiki.jp/kancolle/%E9%9B%B6%E5%BC%8F%E6%B0%B4%E4%B8%8A%E5%81%B5%E5%AF%9F%E6%A9%9F"}, {"text": "作戦報酬", "href": "https://wikiwiki.jp/kancolle/%E6%83%85%E5%A0%B1%E5%80%89%E5%BA%AB#PastRewards"}], "evidenceKind": "list-item", "context": "初期装備艦"}, {"types": ["ship", "development", "improvement"], "availability": "current-or-summary", "rawText": "開発も改修も可能なので更新で入手するメリットは特に無い。", "links": [], "evidenceKind": "list-item", "context": "初期装備艦"}, {"types": ["ship", "ranking"], "availability": "historical", "rawText": "2013年 06月作戦報酬 (1位～340位)", "links": [{"text": "作戦報酬", "href": "https://wikiwiki.jp/kancolle/%E6%83%85%E5%A0%B1%E5%80%89%E5%BA%AB#PastRewards"}], "evidenceKind": "list-item", "context": "過去の入手方法"}], "methodCount": 9, "unclassifiedEvidenceCount": 0, "issueCount": 0, "accepted": true, "coverageStatus": "parsed", "schemaVersion": 3, "resolvedShipIds": [131, 143, 348, 451], "resolvedQuestKeys": [], "referenceIssueCount": 2, "referenceSchemaVersion": 2, "rawEvidence": {"cacheKey": "wikiwiki.jp/kancolle/%E9%9B%B6%E5%BC%8F%E6%B0%B4%E4%B8%8A%E8%A6%B3%E6%B8%AC%E6%A9%9F.html", "rawPath": ".spider/local/source-cache/wikiwiki.jp/kancolle/%E9%9B%B6%E5%BC%8F%E6%B0%B4%E4%B8%8A%E8%A6%B3%E6%B8%AC%E6%A9%9F.html", "contentSha256": "7f40546b98d9146c63ddf77f3ef6ca585dd25456d2af36bcb1f296bd6945032b", "fetchedAt": 1783532268, "validatedAt": 1783532268, "acquisitionSource": "external-browser-session-crawl"}, "fetchAttempts": [{"candidateSource": "raw-cache", "status": "ok", "url": "https://wikiwiki.jp/kancolle/%E9%9B%B6%E5%BC%8F%E6%B0%B4%E4%B8%8A%E8%A6%B3%E6%B8%AC%E6%A9%9F", "cachePath": "wikiwiki.jp/kancolle/%E9%9B%B6%E5%BC%8F%E6%B0%B4%E4%B8%8A%E8%A6%B3%E6%B8%AC%E6%A9%9F.html", "contentSha256": "7f40546b98d9146c63ddf77f3ef6ca585dd25456d2af36bcb1f296bd6945032b"}]}
