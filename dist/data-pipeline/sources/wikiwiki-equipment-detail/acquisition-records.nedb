References": [{"rawName": "更新であるため、震電改二(艦戦型改二)は任務達成後に失われる。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest"], "availability": "current-or-summary", "rawText": "後述の通り特殊な装備であるため、任務をこなすか否かは慎重に判断したい。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "後述の通り特殊な装備であるため、任務をこなすか否かは慎重に判断したい。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}], "methodCount": 5, "unclassifiedEvidenceCount": 0, "issueCount": 0, "accepted": true, "coverageStatus": "parsed", "schemaVersion": 3, "resolvedShipIds": [], "resolvedQuestKeys": [], "referenceIssueCount": 4, "referenceSchemaVersion": 2, "rawEvidence": {"cacheKey": "wikiwiki.jp/kancolle/%E9%9C%87%E9%9B%BB%E6%94%B9%E4%B8%89%28%E8%A9%A6%E8%A3%BD%20%E5%99%B4%E5%BC%8F%E9%9C%87%E9%9B%BB%29.html", "rawPath": ".spider/local/source-cache/wikiwiki.jp/kancolle/%E9%9C%87%E9%9B%BB%E6%94%B9%E4%B8%89%28%E8%A9%A6%E8%A3%BD%20%E5%99%B4%E5%BC%8F%E9%9C%87%E9%9B%BB%29.html", "contentSha256": "c9af1dfd2cb0749a5a78dcb1247e51dd51c4782e81fb57696fcb81385aa03b13", "fetchedAt": 1783527985, "validatedAt": 1783527985, "acquisitionSource": "external-browser-session-crawl"}, "fetchAttempts": [{"candidateSource": "raw-cache", "status": "ok", "url": "https://wikiwiki.jp/kancolle/%E9%9C%87%E9%9B%BB%E6%94%B9%E4%B8%89%28%E8%A9%A6%E8%A3%BD%20%E5%99%B4%E5%BC%8F%E9%9C%87%E9%9B%BB%29", "cachePath": "wikiwiki.jp/kancolle/%E9%9C%87%E9%9B%BB%E6%94%B9%E4%B8%89%28%E8%A9%A6%E8%A3%BD%20%E5%99%B4%E5%BC%8F%E9%9C%87%E9%9B%BB%29.html", "contentSha256": "c9af1dfd2cb0749a5a78dcb1247e51dd51c4782e81fb57696fcb81385aa03b13"}]}
