apiSortno": 200, "apiAftershipId": 0}, "linkTarget": "阿武隈改二", "linkHref": "https://wikiwiki.jp/kancolle/%E9%98%BF%E6%AD%A6%E9%9A%88%E6%94%B9%E4%BA%8C"}, {"rawName": "大潮改二", "shipId": 199, "shipName": "大潮改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 199, "canonicalShipName": "大潮改二", "start2Ship": {"shipId": 199, "shipName": "大潮改二", "apiSortno": 199, "apiAftershipId": 0}, "linkTarget": "大潮改二", "linkHref": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E6%BD%AE%E6%94%B9%E4%BA%8C"}, {"rawName": "鬼怒改二", "shipId": 487, "shipName": "鬼怒改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 487, "canonicalShipName": "鬼怒改二", "start2Ship": {"shipId": 487, "shipName": "鬼怒改二", "apiSortno": 287, "apiAftershipId": 0}, "linkTarget": "鬼怒改二", "linkHref": "https://wikiwiki.jp/kancolle/%E9%AC%BC%E6%80%92%E6%94%B9%E4%BA%8C"}, {"rawName": "荒潮改二", "shipId": 490, "shipName": "荒潮改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 490, "canonicalShipName": "荒潮改二", "start2Ship": {"shipId": 490, "shipName": "荒潮改二", "apiSortno": 290, "apiAftershipId": 0}, "linkTarget": "荒潮改二", "linkHref": "https://wikiwiki.jp/kancolle/%E8%8D%92%E6%BD%AE%E6%94%B9%E4%BA%8C"}, {"rawName": "霰改二", "shipId": 198, "shipName": "霰改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 198, "canonicalShipName": "霰改二", "start2Ship": {"shipId": 198, "shipName": "霰改二", "apiSortno": 198, "apiAftershipId": 0}, "linkTarget": "霰改二", "linkHref": "https://wikiwiki.jp/kancolle/%E9%9C%B0%E6%94%B9%E4%BA%8C"}, {"rawName": "浦波改二", "shipId": 647, "shipName": "浦波改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 647, "canonicalShipName": "浦波改二", "start2Ship": {"shipId": 647, "shipName": "浦波改二", "apiSortno": 447, "apiAftershipId": 0}, "linkTarget": "浦波改二", "linkHref": "https://wikiwiki.jp/kancolle/%E6%B5%A6%E6%B3%A2%E6%94%B9%E4%BA%8C"}, {"rawName": "神州丸改", "shipId": 626, "shipName": "神州丸改", "status": "resolved", "resolution": "start2-name", "evidence": "method-text", "canonicalShipId": 626, "canonicalShipName": "神州丸改", "start2Ship": {"shipId": 626, "shipName": "神州丸改", "apiSortno": 426, "apiAftershipId": 0}}], "questReferences": [{"rawName": "現在は、開発やあきつ丸、神州丸/改、阿武隈改二、大潮改二、鬼怒改二、荒潮改二、霰改二、浦波改二の初期装備や任務報酬などの様々な方法で入手できる。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["development"], "availability": "current", "rawText": "2021年12月10日アップデートで開発可能となった。\n開発秘書艦は揚陸艦、宗谷(特務艦のみ)。理論値の10/10/10/10で開発可能。", "links": [{"text": "揚陸艦", "href": "https://wikiwiki.jp/kancolle/%E8%89%A6%E5%A8%98%E5%90%8D%E4%B8%80%E8%A6%A7%EF%BC%88%E8%89%A6%E7%A8%AE%E5%88%A5%EF%BC%89#LHA_AmphibiousAssaultShip"}, {"text": "宗谷(特務艦のみ)", "href": "https://wikiwiki.jp/kancolle/%E5%AE%97%E8%B0%B7"}], "evidenceKind": "list-item", "context": "開発"}, {"types": ["construction", "event"], "availability": "mixed-summary", "rawText": "あきつ丸は大型艦建造と南西海域/7-5第3ゲージでのドロップで狙える。\n通常海域ドロップが設定される以前は、イベント海域でのドロップ狙いで掘った方が大型建造よりもやや有利という意見もみられたが、長らくイベント海域ドロップが設定されず、あきつ丸入手に苦心する提督も多かった模様。7-5-3ドロップが設定された現在も、イベント海域でドロップする機会があるならば他のレアドロップ艦と同時に掘る選択肢も考えられる。", "links": [{"text": "大型艦建造", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E5%9E%8B%E8%89%A6%E5%BB%BA%E9%80%A0"}, {"text": "南西海域/7-5", "href": "https://wikiwiki.jp/kancolle/%E5%8D%97%E8%A5%BF%E6%B5%B7%E5%9F%9F/7-5"}, {"text": "伊401", "href": "https://wikiwiki.jp/kancolle/%E4%BC%8A401"}, {"text": "大鳳", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E9%B3%B3"}, {"text": "大和", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E5%92%8C"}, {"text": "武蔵", "href": "https://wikiwiki.jp/kancolle/%E6%AD%A6%E8%94%B5"}, {"text": "ビスマルク", "href": "https://wikiwiki.jp/kancolle/Bismarck"}, {"text": "カ号観測機", "href": "https://wikiwiki.jp/kancolle/%E3%82%AB%E5%8F%B7%E8%A6%B3%E6%B8%AC%E6%A9%9F"}, {"text": "三式指揮連絡機(対潜)", "href": "https://wikiwiki.jp/kancolle/%E4%B8%89%E5%BC%8F%E6%8C%87%E6%8F%AE%E9%80%A3%E7%B5%A1%E6%A9%9F%28%E5%AF%BE%E6%BD%9C%29"}, {"text": "対潜支援", "href": "https://wikiwiki.jp/kancolle/%E6%94%AF%E6%8F%B4%E8%89%A6%E9%9A%8A#i0093bc7"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["construction", "event"], "availability": "mixed-summary", "rawText": "地道に資源を貯める根気があれば、大型艦建造は最も手間のかからない容易な入手手段。", "links": [{"text": "伊401", "href": "https://wikiwiki.jp/kancolle/%E4%BC%8A401"}, {"text": "大鳳", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E9%B3%B3"}, {"text": "大和", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E5%92%8C"}, {"text": "武蔵", "href": "https://wikiwiki.jp/kancolle/%E6%AD%A6%E8%94%B5"}, {"text": "ビスマルク", "href": "https://wikiwiki.jp/kancolle/Bismarck"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["construction", "event"], "availability": "mixed-summary", "rawText": "資源の自然増加を利用しながらの建造であれば、建造コストはさほど問題にならない。", "links": [{"text": "伊401", "href": "https://wikiwiki.jp/kancolle/%E4%BC%8A401"}, {"text": "大鳳", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E9%B3%B3"}, {"text": "大和", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E5%92%8C"}, {"text": "武蔵", "href": "https://wikiwiki.jp/kancolle/%E6%AD%A6%E8%94%B5"}, {"text": "ビスマルク", "href": "https://wikiwiki.jp/kancolle/Bismarck"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["construction", "event"], "availability": "mixed-summary", "rawText": "イベント前などに自然増加上限以上の備蓄を行う際は、本装備の数が多いほど時間効率が良くなるので、大型艦建造を回せる時に回すというものである。", "links": [{"text": "伊401", "href": "https://wikiwiki.jp/kancolle/%E4%BC%8A401"}, {"text": "大鳳", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E9%B3%B3"}, {"text": "大和", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E5%92%8C"}, {"text": "武蔵", "href": "https://wikiwiki.jp/kancolle/%E6%AD%A6%E8%94%B5"}, {"text": "ビスマルク", "href": "https://wikiwiki.jp/kancolle/Bismarck"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["construction", "event"], "availability": "mixed-summary", "rawText": "本装備を資源回復速度を上げるための道具と捉えれば、無理に元を取る必要はない。", "links": [{"text": "伊401", "href": "https://wikiwiki.jp/kancolle/%E4%BC%8A401"}, {"text": "大鳳", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E9%B3%B3"}, {"text": "大和", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E5%92%8C"}, {"text": "武蔵", "href": "https://wikiwiki.jp/kancolle/%E6%AD%A6%E8%94%B5"}, {"text": "ビスマルク", "href": "https://wikiwiki.jp/kancolle/Bismarck"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["construction"], "availability": "mixed-summary", "rawText": "伊401、大鳳、大和、武蔵、ビスマルクなどを狙うレシピで、あきつ丸も副産物的に出る可能性がある点にも留意されたい。", "links": [{"text": "伊401", "href": "https://wikiwiki.jp/kancolle/%E4%BC%8A401"}, {"text": "大鳳", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E9%B3%B3"}, {"text": "大和", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E5%92%8C"}, {"text": "武蔵", "href": "https://wikiwiki.jp/kancolle/%E6%AD%A6%E8%94%B5"}, {"text": "ビスマルク", "href": "https://wikiwiki.jp/kancolle/Bismarck"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["construction", "development"], "availability": "mixed-summary", "rawText": "大発は増えないがレベルを25まで上げ、副産物でカ号観測機と三式指揮連絡機(対潜)も量産可能。", "links": [{"text": "カ号観測機", "href": "https://wikiwiki.jp/kancolle/%E3%82%AB%E5%8F%B7%E8%A6%B3%E6%B8%AC%E6%A9%9F"}, {"text": "三式指揮連絡機(対潜)", "href": "https://wikiwiki.jp/kancolle/%E4%B8%89%E5%BC%8F%E6%8C%87%E6%8F%AE%E9%80%A3%E7%B5%A1%E6%A9%9F%28%E5%AF%BE%E6%BD%9C%29"}, {"text": "対潜支援", "href": "https://wikiwiki.jp/kancolle/%E6%94%AF%E6%8F%B4%E8%89%A6%E9%9A%8A#i0093bc7"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["construction", "development"], "availability": "mixed-summary", "rawText": "(あきつ丸での開発も可能だが)対潜支援に有用。", "links": [{"text": "カ号観測機", "href": "https://wikiwiki.jp/kancolle/%E3%82%AB%E5%8F%B7%E8%A6%B3%E6%B8%AC%E6%A9%9F"}, {"text": "三式指揮連絡機(対潜)", "href": "https://wikiwiki.jp/kancolle/%E4%B8%89%E5%BC%8F%E6%8C%87%E6%8F%AE%E9%80%A3%E7%B5%A1%E6%A9%9F%28%E5%AF%BE%E6%BD%9C%29"}, {"text": "対潜支援", "href": "https://wikiwiki.jp/kancolle/%E6%94%AF%E6%8F%B4%E8%89%A6%E9%9A%8A#i0093bc7"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["construction", "event"], "availability": "current", "rawText": "現状では、神州丸の入手方法はイベント突破報酬あるいはイベント海域でのドロップのみ。\n特徴として、Lv48以上まで育成し改にすることで、改装設計図を使わずに2つの大発動艇を入手できる。", "links": [{"text": "改", "href": "https://wikiwiki.jp/kancolle/%E7%A5%9E%E5%B7%9E%E4%B8%B8%E6%94%B9"}, {"text": "期間限定", "href": "https://wikiwiki.jp/kancolle/%E6%9C%9F%E9%96%93%E9%99%90%E5%AE%9A%E3%83%89%E3%83%AD%E3%83%83%E3%83%97%E3%82%A4%E3%83%99%E3%83%B3%E3%83%88#m51058fb"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["construction"], "availability": "current", "rawText": "2021/01/13から2-3-N(ボス)において期間限定でドロップするようになった。", "links": [{"text": "期間限定", "href": "https://wikiwiki.jp/kancolle/%E6%9C%9F%E9%96%93%E9%99%90%E5%AE%9A%E3%83%89%E3%83%AD%E3%83%83%E3%83%97%E3%82%A4%E3%83%99%E3%83%B3%E3%83%88#m51058fb"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["construction"], "availability": "current", "rawText": "（2023/06/28現在も継続中）", "links": [{"text": "期間限定", "href": "https://wikiwiki.jp/kancolle/%E6%9C%9F%E9%96%93%E9%99%90%E5%AE%9A%E3%83%89%E3%83%AD%E3%83%83%E3%83%97%E3%82%A4%E3%83%99%E3%83%B3%E3%83%88#m51058fb"}], "evidenceKind": "list-item", "context": "ドロップ・建造"}, {"types": ["ship"], "availability": "current-or-summary", "rawText": "阿武隈改二、大潮改二、鬼怒改二、荒潮改二、霰改二、浦波改二の初期装備だが、いずれも改装に設計図が必要となる。", "links": [{"text": "阿武隈改二", "href": "https://wikiwiki.jp/kancolle/%E9%98%BF%E6%AD%A6%E9%9A%88%E6%94%B9%E4%BA%8C"}, {"text": "大潮改二", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E6%BD%AE%E6%94%B9%E4%BA%8C"}, {"text": "鬼怒改二", "href": "https://wikiwiki.jp/kancolle/%E9%AC%BC%E6%80%92%E6%94%B9%E4%BA%8C"}, {"text": "荒潮改二", "href": "https://wikiwiki.jp/kancolle/%E8%8D%92%E6%BD%AE%E6%94%B9%E4%BA%8C"}, {"text": "霰改二", "href": "https://wikiwiki.jp/kancolle/%E9%9C%B0%E6%94%B9%E4%BA%8C"}, {"text": "浦波改二", "href": "https://wikiwiki.jp/kancolle/%E6%B5%A6%E6%B3%A2%E6%94%B9%E4%BA%8C"}, {"text": "甲", "href": "https://wikiwiki.jp/kancolle/%E7%94%B2%E6%A8%99%E7%9A%84%20%E7%94%B2%E5%9E%8B"}, {"text": "標", "href": "https://wikiwiki.jp/kancolle/%E7%94%B2%E6%A8%99%E7%9A%84%20%E4%B8%99%E5%9E%8B"}, {"text": "的", "href": "https://wikiwiki.jp/kancolle/%E7%94%B2%E6%A8%99%E7%9A%84%20%E4%B8%81%E5%9E%8B%E6%94%B9%28%E8%9B%9F%E9%BE%8D%E6%94%B9%29"}], "evidenceKind": "list-item", "context": "改装時の初期装備", "shipReferences": [{"rawName": "阿武隈改二", "shipId": 200, "shipName": "阿武隈改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 200, "canonicalShipName": "阿武隈改二", "start2Ship": {"shipId": 200, "shipName": "阿武隈改二", "apiSortno": 200, "apiAftershipId": 0}, "linkTarget": "阿武隈改二", "linkHref": "https://wikiwiki.jp/kancolle/%E9%98%BF%E6%AD%A6%E9%9A%88%E6%94%B9%E4%BA%8C"}, {"rawName": "大潮改二", "shipId": 199, "shipName": "大潮改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 199, "canonicalShipName": "大潮改二", "start2Ship": {"shipId": 199, "shipName": "大潮改二", "apiSortno": 199, "apiAftershipId": 0}, "linkTarget": "大潮改二", "linkHref": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E6%BD%AE%E6%94%B9%E4%BA%8C"}, {"rawName": "鬼怒改二", "shipId": 487, "shipName": "鬼怒改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 487, "canonicalShipName": "鬼怒改二", "start2Ship": {"shipId": 487, "shipName": "鬼怒改二", "apiSortno": 287, "apiAftershipId": 0}, "linkTarget": "鬼怒改二", "linkHref": "https://wikiwiki.jp/kancolle/%E9%AC%BC%E6%80%92%E6%94%B9%E4%BA%8C"}, {"rawName": "荒潮改二", "shipId": 490, "shipName": "荒潮改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 490, "canonicalShipName": "荒潮改二", "start2Ship": {"shipId": 490, "shipName": "荒潮改二", "apiSortno": 290, "apiAftershipId": 0}, "linkTarget": "荒潮改二", "linkHref": "https://wikiwiki.jp/kancolle/%E8%8D%92%E6%BD%AE%E6%94%B9%E4%BA%8C"}, {