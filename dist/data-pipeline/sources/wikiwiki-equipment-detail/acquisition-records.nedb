 "apiAftershipId": 219}, "linkTarget": "五十鈴", "linkHref": "https://wikiwiki.jp/kancolle/%E4%BA%94%E5%8D%81%E9%88%B4"}, {"rawName": "北上改二", "shipId": 119, "shipName": "北上改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 119, "canonicalShipName": "北上改二", "start2Ship": {"shipId": 119, "shipName": "北上改二", "apiSortno": 115, "apiAftershipId": 0}, "linkTarget": "北上改二", "linkHref": "https://wikiwiki.jp/kancolle/%E5%8C%97%E4%B8%8A%E6%94%B9%E4%BA%8C"}, {"rawName": "大井改二", "shipId": 118, "shipName": "大井改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 118, "canonicalShipName": "大井改二", "start2Ship": {"shipId": 118, "shipName": "大井改二", "apiSortno": 114, "apiAftershipId": 0}, "linkTarget": "大井改二", "linkHref": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E4%BA%95%E6%94%B9%E4%BA%8C"}, {"rawName": "三隈改", "shipId": 121, "shipName": "三隈改", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 121, "canonicalShipName": "三隈改", "start2Ship": {"shipId": 121, "shipName": "三隈改", "apiSortno": 117, "apiAftershipId": 502}, "linkTarget": "三隈改", "linkHref": "https://wikiwiki.jp/kancolle/%E4%B8%89%E9%9A%88%E6%94%B9"}]}, {"types": ["ship"], "availability": "historical", "rawText": "ほかには北上改二・大井改二・三隈改が持参するため、牧場のオマケで増えてる場合もある。", "links": [{"text": "北上改二", "href": "https://wikiwiki.jp/kancolle/%E5%8C%97%E4%B8%8A%E6%94%B9%E4%BA%8C"}, {"text": "大井改二", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E4%BA%95%E6%94%B9%E4%BA%8C"}, {"text": "三隈改", "href": "https://wikiwiki.jp/kancolle/%E4%B8%89%E9%9A%88%E6%94%B9"}, {"text": "その他持参艦", "href": "https://wikiwiki.jp/kancolle/%E3%81%BE%E3%82%81%E3%81%A1%E3%81%97%E3%81%8D#bb1f99a5"}], "evidenceKind": "list-item", "shipReferences": [{"rawName": "北上改二", "shipId": 119, "shipName": "北上改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 119, "canonicalShipName": "北上改二", "start2Ship": {"shipId": 119, "shipName": "北上改二", "apiSortno": 115, "apiAftershipId": 0}, "linkTarget": "北上改二", "linkHref": "https://wikiwiki.jp/kancolle/%E5%8C%97%E4%B8%8A%E6%94%B9%E4%BA%8C"}, {"rawName": "大井改二", "shipId": 118, "shipName": "大井改二", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 118, "canonicalShipName": "大井改二", "start2Ship": {"shipId": 118, "shipName": "大井改二", "apiSortno": 114, "apiAftershipId": 0}, "linkTarget": "大井改二", "linkHref": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E4%BA%95%E6%94%B9%E4%BA%8C"}, {"rawName": "三隈改", "shipId": 121, "shipName": "三隈改", "status": "resolved", "resolution": "start2-name", "evidence": "link-text", "canonicalShipId": 121, "canonicalShipName": "三隈改", "start2Ship": {"shipId": 121, "shipName": "三隈改", "apiSortno": 117, "apiAftershipId": 502}, "linkTarget": "三隈改", "linkHref": "https://wikiwiki.jp/kancolle/%E4%B8%89%E9%9A%88%E6%94%B9"}]}, {"types": ["ship"], "availability": "historical", "rawText": "その他持参艦", "links": [{"text": "その他持参艦", "href": "https://wikiwiki.jp/kancolle/%E3%81%BE%E3%82%81%E3%81%A1%E3%81%97%E3%81%8D#bb1f99a5"}], "evidenceKind": "list-item"}, {"types": ["development"], "availability": "historical", "rawText": "地味に開発背景はホロ背景、そりゃ出にくいわけだわ(違", "links": [], "evidenceKind": "list-item"}, {"types": ["quest"], "availability": "historical", "rawText": "17年6月以降「電探の廃棄」を伴なう任務が出てきた為、廃棄任務用に2個以上常備しておくのも良い。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "17年6月以降「電探の廃棄」を伴なう任務が出てきた為、廃棄任務用に2個以上常備しておくのも良い。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest"], "availability": "historical", "rawText": "捨てるための存在というのもいささかなものではあるが", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "捨てるための存在というのもいささかなものではあるが", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest"], "availability": "historical", "rawText": "18年3月23日アプデにて、クォータリーで電探廃棄を伴なう任務が実装された。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "18年3月23日アプデにて、クォータリーで電探廃棄を伴なう任務が実装された。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest"], "availability": "historical", "rawText": "要求個数は4個。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "要求個数は4個。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["development", "quest"], "availability": "current", "rawText": "報酬が開発可能になっているため後続の任務をやらないなら必要性は薄い。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "報酬が開発可能になっているため後続の任務をやらないなら必要性は薄い。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["development"], "availability": "current-or-summary", "rawText": "開発、開発率は2%で最低値。", "links": [{"text": "開発", "href": "https://wikiwiki.jp/kancolle/%E9%96%8B%E7%99%BA"}, {"text": "開発率", "href": "https://wikiwiki.jp/kancolle/%E9%96%8B%E7%99%BA#ucc0ea0a"}], "evidenceKind": "list-item"}, {"types": ["development"], "availability": "current-or-summary", "rawText": "2021/03/30から秋月型秘書艦だと開発率が向上するようになった。", "links": [{"text": "開発率", "href": "https://wikiwiki.jp/kancolle/%E9%96%8B%E7%99%BA#ucc0ea0a"}], "evidenceKind": "list-item"}, {"types": ["development"], "availability": "current-or-summary", "rawText": "ボーキテーブルが最も高く10/10/200/201で開発率6%。", "links": [{"text": "開発率", "href": "https://wikiwiki.jp/kancolle/%E9%96%8B%E7%99%BA#ucc0ea0a"}], "evidenceKind": "list-item"}, {"types": ["development"], "availability": "current-or-summary", "rawText": "尚、アイコン自体の背景は銀色だが、装備選択画面で分かるように内部的には「ホロ」として分類されているので、開発の際は司令部Lv20が必要で背景はホロで表示される*3", "links": [], "evidenceKind": "list-item"}], "methodCount": 13, "unclassifiedEvidenceCount": 0, "issueCount": 0, "accepted": true, "coverageStatus": "parsed", "schemaVersion": 3, "resolvedShipIds": [22, 118, 119, 121, 219], "resolvedQuestKeys": [], "referenceIssueCount": 5, "referenceSchemaVersion": 2, "rawEvidence": {"cacheKey": "wikiwiki.jp/kancolle/21%E5%8F%B7%E5%AF%BE%E7%A9%BA%E9%9B%BB%E6%8E%A2.html", "rawPath": ".spider/local/source-cache/wikiwiki.jp/kancolle/21%E5%8F%B7%E5%AF%BE%E7%A9%BA%E9%9B%BB%E6%8E%A2.html", "contentSha256": "68682390bf5412ebadb2b707bbf5e80751fb7a10bf702e088c19cab0cec23b1f", "fetchedAt": 1783531741, "validatedAt": 1783531741, "acquisitionSource": "external-browser-session-crawl"}, "fetchAttempts": [{"candidateSource": "raw-cache", "status": "ok", "url": "https://wikiwiki.jp/kancolle/21%E5%8F%B7%E5%AF%BE%E7%A9%BA%E9%9B%BB%E6%8E%A2", "cachePath": "wikiwiki.jp/kancolle/21%E5%8F%B7%E5%AF%BE%E7%A9%BA%E9%9B%BB%E6%8E%A2.html", "contentSha256": "68682390bf5412ebadb2b707bbf5e80751fb7a10bf702e088c19cab0cec23b1f"}]}
