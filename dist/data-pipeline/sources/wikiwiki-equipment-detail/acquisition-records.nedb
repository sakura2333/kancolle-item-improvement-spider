iki.jp/kancolle/Samuel%20B.Roberts%20Mk.II"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "2-3以外はどこも一筋縄ではいかないため、創意工夫が必要となる。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest"], "availability": "current-or-summary", "rawText": "それ以前にTaffy IIIが揃ってないと任務解放すら到達できないのだが", "links": [{"text": "Mk.II", "href": "https://wikiwiki.jp/kancolle/Samuel%20B.Roberts%20Mk.II"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "それ以前にTaffy IIIが揃ってないと任務解放すら到達できないのだが", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["exchange"], "availability": "current-or-summary", "rawText": "その分、選択報酬として補強増設×2も選べる(他はFM-2★+7・改修資材×7)ので、本装備を含めて挑戦する価値は高い。", "links": [{"text": "FM-2", "href": "https://wikiwiki.jp/kancolle/FM-2"}], "evidenceKind": "list-item"}], "methodCount": 4, "unclassifiedEvidenceCount": 0, "issueCount": 0, "accepted": true, "coverageStatus": "parsed", "schemaVersion": 3, "resolvedShipIds": [], "resolvedQuestKeys": [], "referenceIssueCount": 3, "referenceSchemaVersion": 2, "rawEvidence": {"cacheKey": "wikiwiki.jp/kancolle/Mk.32%20%E5%AF%BE%E6%BD%9C%E9%AD%9A%E9%9B%B7%28Mk.2%E8%90%BD%E5%B0%84%E6%A9%9F%29", "rawPath": ".spider/local/source-cache/wikiwiki.jp/kancolle/Mk.32%20%E5%AF%BE%E6%BD%9C%E9%AD%9A%E9%9B%B7%28Mk.2%E8%90%BD%E5%B0%84%E6%A9%9F%29", "contentSha256": "3b7101bd778ea314ae76fa1b215d25cc6382850d9317efa7bbeeb3f5a14df92d", "fetchedAt": 1783526448, "validatedAt": 1783526448, "acquisitionSource": "external-browser-session-crawl"}, "fetchAttempts": [{"candidateSource": "raw-cache", "status": "ok", "url": "https://wikiwiki.jp/kancolle/Mk.32%20%E5%AF%BE%E6%BD%9C%E9%AD%9A%E9%9B%B7%28Mk.2%E8%90%BD%E5%B0%84%E6%A9%9F%29", "cachePath": "wikiwiki.jp/kancolle/Mk.32%20%E5%AF%BE%E6%BD%9C%E9%AD%9A%E9%9B%B7%28Mk.2%E8%90%BD%E5%B0%84%E6%A9%9F%29", "contentSha256": "3b7101bd778ea314ae76fa1b215d25cc6382850d9317efa7bbeeb3f