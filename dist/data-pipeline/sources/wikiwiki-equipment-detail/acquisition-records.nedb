B%29"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "任務『三十二駆「藤波改二」、鳥海を護衛せよ！』選択報酬", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "improvement"], "availability": "current", "rawText": "13号後期型は改修更新で入手可能なため選択は非推奨。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "13号後期型は改修更新で入手可能なため選択は非推奨。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "improvement"], "availability": "current", "rawText": "逆探との選択だが、後続の早波任務と合わせてD3砲と逆探をそれぞれ一個づつ入手するのが安全択だろう。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "逆探との選択だが、後続の早波任務と合わせてD3砲と逆探をそれぞれ一個づつ入手するのが安全択だろう。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "exchange"], "availability": "current-or-summary", "rawText": "任務『三十二駆「早波改二」、元気に出撃せよ！』選択報酬", "links": [{"text": "三十二駆「早波改二」、元気に出撃せよ！", "href": "https://wikiwiki.jp/kancolle/%E4%BB%BB%E5%8B%99#id-B213"}, {"text": "四式水中聴音機", "href": "https://wikiwiki.jp/kancolle/%E5%9B%9B%E5%BC%8F%E6%B0%B4%E4%B8%AD%E8%81%B4%E9%9F%B3%E6%A9%9F"}, {"text": "逆探(E27)＋22号対水上電探改四(後期調整型)", "href": "https://wikiwiki.jp/kancolle/%E9%80%86%E6%8E%A2%28E27%29%EF%BC%8B22%E5%8F%B7%E5%AF%BE%E6%B0%B4%E4%B8%8A%E9%9B%BB%E6%8E%A2%E6%94%B9%E5%9B%9B%28%E5%BE%8C%E6%9C%9F%E8%AA%BF%E6%95%B4%E5%9E%8B%29"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "任務『三十二駆「早波改二」、元気に出撃せよ！』選択報酬", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "improvement"], "availability": "current", "rawText": "四ソは改修更新で入手可能なため選択は非推奨。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "四ソは改修更新で入手可能なため選択は非推奨。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"typ