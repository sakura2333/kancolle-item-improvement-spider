": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest"], "availability": "current", "rawText": "クォータリー出撃任務『北方海域警備を実施せよ！』で3か月おきに1個入手できる。", "links": [{"text": "北方海域警備を実施せよ！", "href": "https://wikiwiki.jp/kancolle/%E4%BB%BB%E5%8B%99#id-Bq5"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "クォータリー出撃任務『北方海域警備を実施せよ！』で3か月おきに1個入手できる。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest"], "availability": "current", "rawText": "クォータリー遠征任務『海上通商航路の警戒を厳とせよ！』で3か月おきに2個入手できる。", "links": [{"text": "海上通商航路の警戒を厳とせよ！", "href": "https://wikiwiki.jp/kancolle/%E4%BB%BB%E5%8B%99#id-Dq1"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "クォータリー遠征任務『海上通商航路の警戒を厳とせよ！』で3か月おきに2個入手できる。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "exchange"], "availability": "current-or-summary", "rawText": "イヤーリー(6月)出撃任務『南西方面の兵站航路の安全を図れ！』選択報酬", "links": [{"text": "南西方面の兵站航路の安全を図れ！", "href": "https://wikiwiki.jp/kancolle/%E4%BB%BB%E5%8B%99#id-By7"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "イヤーリー(6月)出撃任務『南西方面の兵站航路の安全を図れ！』選択報酬", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "exchange"], "availability": "current-or-summary", "rawText": "イヤーリー(11月)近代化任務『「駆逐艦」の改修工事を実施せよ！』選択報酬", "links": [{"text": "「駆逐艦」の改修工事を実施せよ！", "href": "https://wikiwiki.jp/kancolle/%E4%BB%BB%E5%8B%99#id-Gy1"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "イヤーリー(11月)近代化任務『「駆逐艦」の改修工事を実施せよ！』選択報酬", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "exchange"], "availability": "current-or-summary", "rawText": "逆にこの装備を消費する任務としては、月1任務でおにぎり2個を伊良湖1個へと交換できる任務「給糧艦「伊良湖」の支援」が実装されている。", "links": [{"text": "給糧艦「伊良湖」の支援", "href": "https://wikiwiki.jp/kancolle/%E4%BB%BB%E5%8B%99#id-Cm2"}], "evidenceKind": "list-item", "questReferences": [{"rawName": "逆にこの装備を消費する任務としては、月1任務でおにぎり2個を伊良湖1個へと交換できる任務「給糧艦「伊良湖」の支援」が実装されている。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "exchange"], "availability": "current", "rawText": "なおマンスリーとクォータリー任務でおにぎりを入手できる任務を毎月実行すると四半期毎におにぎりが6つとなる。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "なおマンスリーとクォータリー任務でおにぎりを入手できる任務を毎月実行すると四半期毎におにぎりが6つとなる。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "exchange"], "availability": "current", "rawText": "そのため実質差し引き0で伊良湖3個に交換できる。", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "そのため実質差し引き0で伊良湖3個に交換できる。", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}, {"types": ["quest", "exchange"], "availability": "current", "rawText": "本来の使い方と絶対違うが", "links": [], "evidenceKind": "list-item", "questReferences": [{"rawName": "本来の使い方と絶対違うが", "questKey": null, "questCode": null, "questName": null, "status": "unresolved", "evidence": "method-text"}]}], "methodCount": 10, "unclassifiedEvidenceCount": 0, "issueCount": 0, "accepted": true, "coverageStatus": "parsed", "schemaVersion": 3, "resolvedShipIds": [], "resolvedQuestKeys": [], "referenceIssueCount": 10, "referenceSchemaVersion": 2, "rawEvidence": {"cacheKey": "wikiwiki.jp/kancolle/%E6%88%A6%E9%97%98%E7%B3%A7%E9%A3%9F.html", "rawPath": ".spider/local/source-cache/wikiwiki.jp/kancolle/%E6%88%A6%E9%97%98%E7%B3%A7%E9%A3%9F.html", "contentSha256": "b88b0ae80d253f8d8572ea2ac8bad8adb587d49166ab3ddc09830ce8fe156e7f", "fetchedAt": 1783534881, "validatedAt": 1783534881, "acquisitionSource": "external-browser-session-crawl"}, "fetchAttempts": [{"candidateSource": "raw-cache", "status": "ok", "url": "https