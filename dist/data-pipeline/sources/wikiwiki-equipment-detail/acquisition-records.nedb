{"equipmentId": 245, "equipmentName": "38cm四連装砲", "source": "wikiwiki-equipment-detail", "sourceUrl": "https://wikiwiki.jp/kancolle/38cm%E5%9B%9B%E9%80%A3%E8%A3%85%E7%A0%B2", "pageEquipmentId": 245, "sectionHeading": "入手方法について", "evidenceScope": "acquisition-section", "developmentAvailable": true, "developmentResolution": {"status": "resolved", "method": "wikiwiki-equipment-infobox-notes", "marker": "開発解禁日", "rawText": "開発解禁日：2025年10月17日、改修可、入手方法"}, "currentMethodTypes": ["development", "exchange", "quest", "ship"], "historicalMethodTypes": [], "methods": [{"types": ["development"], "availability": "current-or-summary", "rawText": "Richelieu級の鋼材、弾薬テーブルで2%", "links": [{"text": "46cm三連装砲", "href": "https://wikiwiki.jp/kancolle/46cm%E4%B8%89%E9%80%A3%E8%A3%85%E7%A0%B2"}], "evidenceKind": "list-item", "context": "開発"}, {"types": ["development"], "availability": "current-or-summary", "rawText": "理論値(10/200/240/30)", "links": [], "evidenceKind": "list-item", "context": "開発"}, {"types": ["development"], "availability": "current-or-summary", "rawText": "46cm三連装砲との同時狙いも可能。", "links": [{"text": "46cm三連装砲", "href": "https://wikiwiki.jp/kancolle/46cm%E4%B8%89%E9%80%A3%E8%A3%85%E7%A0%B2"}], "evidenceKind": "list-item", "context": "開発"}, {"types": ["development"], "availability": "current-or-summary", "rawText": "他の目当てが無ければ(10/251/250/30)でOK。", "links": [{"text": "46cm三連装砲", "href": "https://wikiwiki.jp/kancolle/46cm%E4%B8%89%E9%80%A3%E8%A3%85%E7%A0%B2"}], "evidenceKind": "list-item", "context": "開発"}, {"types": ["development"], "availability": "current-or-summary", "rawText": "ボーキサイトが最低『30』必要な点に注意。", "links": [{"text": "46cm三連装砲", "href": "https://wikiwiki.jp/kancolle/46cm%E4%B8%89%E9%80%A3%E8%A3%85%E7%A0%B2"}], "evidenceKind": "list-item", "context": "開発"}, {"types": ["development"], "availability": "current-or-summary", "rawText": "所謂大和砲レシピ(10/251/250/10)では開発できない。", "links": [{"text": "46cm三連装砲", "href": "https://wikiwiki.jp/kancolle/46cm%E4%B8%89%E9%80%A3%E8%A3%85%E7%A0%B2"}]