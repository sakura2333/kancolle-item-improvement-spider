  "architectureScope": "manual-flow-subprocess-entry",
  "flow": {
    "registered": true,
    "command": "wikiwiki",
    "execution": "manual-only"
  },
  "build": {
    "ciExecution": false,
    "defaultQualityExecution": false,
    "npmInclusion": false
