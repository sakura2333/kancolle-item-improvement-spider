  "changelogEntries": [
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Added",
      "text": "Added required non-null `developmentAvailable` to unified equipment sources schema 2. The formal value comes from KCWiki `_buildable`, while WikiWiki independently validates the current equipment infobox `備考` marker。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Added",
      "text": "Added source diagnostics for KCWiki/WikiWiki development-availability cross-validation; null, non-boolean, and conflicting values stop package generation with a red error。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Added",
      "text": "Added improvement detail schema 4 with source-faithful ★0..★MAX `levelExpectations`。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Added",
      "text": "Added fixed 11-row route `stepList` data for every normal improvement level and optional MAX conversion。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Added",
      "text": "Preserved conditional effect text separately from simple numeric values so consumers do not apply context-specific bonuses globally。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Added",
      "text": "Added the MAX conversion target name so consumers can render the upgrade result without a separate equipment-master lookup。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Added",
      "text": "Added `schemas/improvement-detail.schema.json` for the schema 4 record contract。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Fixed",
      "text": "Restored ship-acquisition relations for Start2 equipment IDs 142 and 305 when KcWiki uses English “Kai Ni” aliases instead of its canonical equipment names。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Fixed",
      "text": "Added source-scoped, Start2-validated semantic aliases so accepted upstream naming variants cannot silently disappear from the package。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Compatibility",
      "text": "Improvement list schema: 2 (unchanged)。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Compatibility",
      "text": "Improvement detail schema: 4。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Compatibility",
      "text": "Equipment sources schema: 2 (`developmentAvailable` is newly required)。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Compatibility",
      "text": "Consumers that only read existing improvement-detail fields remain compatible; equipment-source consumers must accept the required boolean field。",
      "public": true
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Planned",
      "text": "Add exchange, ranking, and event acquisition methods。",
      "public": false
    },
    {
      "source": "packages/kancolle-data/CHANGELOG.md",
      "version": "Unreleased",
      "section": "Planned",
      "text": "Add additional ship, map, and quest projections when stable schemas are available。",
      "public": false
    }
  ],
