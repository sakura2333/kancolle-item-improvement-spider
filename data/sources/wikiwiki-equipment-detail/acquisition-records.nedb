{"equipmentId": 421, "equipmentName": "SB2C-5", "source": "wikiwiki-equipment-detail", "sourceUrl": "https://wikiwiki.jp/kancolle/SB2C-5", "pageEquipmentId": 421, "sectionHeading": "入手方法について", "evidenceScope": "acquisition-section", "developmentAvailable": false, "currentMethodTypes": ["development", "improvement", "ship"], "historicalMethodTypes": ["event", "ranking"], "methods": [{"types": ["improvement"], "availability": "current-or-summary", "rawText": "SB2C-3からの改修更新", "links": [{"text": "SB2C-3", "href": "https://wikiwiki.jp/kancolle/SB2C-3"}, {"text": "SBD-5", "href": "https://wikiwiki.jp/kancolle/SBD-5"}], "evidenceKind": "list-item"}, {"types": ["ship"], "availability": "current", "rawText": "初期装備で入手可能なSBD-5から作るのが一番手っ取り早い方法か。", "links": [{"text": "SBD-5", "href": "https://wikiwiki.jp/kancolle/SBD-5"}], "evidenceKind": "list-item"}, {"types": ["development"], "availability": "current", "rawText": "SBD-5★0→SB2C-3→本装備と作る場合、開発資材163個、改修資材110個(いずれも★+6以降を確実化した場合)、新型航空兵装資材x4、熟練搭乗員x2が必要。", "links": [], "evidenceKind": "list-item"}, {"types": ["ranking"], "availability": "historical", "rawText": "2021年 05月作戦報酬 (1位～5位)★+5、(6位～20位)★+5、(21位～100位)★なし", "links": [{"text": "作戦報酬", "href": "https://wikiwiki.jp/kancolle/%E6%83%85%E5%A0%B1%E5%80%89%E5%BA%AB#PastRewards"}], "evidenceKind": "list-item", "context": "過去の入手方法"}, {"types": ["ranking"], "availability": "historical", "rawText": "2021年 10月作戦報酬 (1位～5位)★+5、(6位～20位)★+4", "links": [{"text": "作戦報酬", "href": "https://wikiwiki.jp/kancolle/%E6%83%85%E5%A0%B1%E5%80%89%E5%BA%AB#PastRewards"}], "evidenceKind": "list-item", "context": "過去の入手方法"}, {"types": ["ranking"], "availability": "historical", "rawText": "2022年 09月作戦報酬 (1位～5位)★+5、(6位～20位)★+4", "links": [{"text": "作戦報酬", "href": "https://wikiwiki.jp/kancolle/%E6%83%85%E5%A0%B1%E5%80%89%E5%BA%AB#Rewards"}], "evidenceKind": "list-item", "context": "過去の入手方法"}, {"types": ["event"], "availability": "historical", "rawText": "2025年 秋イベント後段作戦『要撃！敵機動部隊捜索撃滅戦』", "links": [{"text": "要撃！敵機