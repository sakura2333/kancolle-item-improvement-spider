ps://wikiwiki.jp/kancolle/SB2C-3"}], "evidenceKind": "list-item"}, {"types": ["development", "ship"], "availability": "current", "rawText": "他の消費装備は開発や初期装備などで入手することが不可能ではないが、これだけは自力で作るしかない。", "links": [{"text": "SB2C-3", "href": "https://wikiwiki.jp/kancolle/SB2C-3"}], "evidenceKind": "list-item"}, {"types": ["event"], "availability": "historical", "rawText": "2022年 夏イベント『大規模反攻上陸！トーチ作戦！』E-3 甲作戦(★+1)・乙作戦(★無し) 突破報酬", "links": [{"text": "大規模反攻上陸！トーチ作戦！", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E8%A6%8F%E6%A8%A1%E5%8F%8D%E6%94%BB%E4%B8%8A%E9%99%B8%EF%BC%81%E3%83%88%E3%83%BC%E3%83%81%E4%BD%9C%E6%88%A6%EF%BC%81"}, {"text": "E-3", "href": "https://wikiwiki.jp/kancolle/%E5%A4%A7%E8%A6%8F%E6%A8%A1%E5%8F%8D%E6%94%BB%E4%B8%8A%E9%99%B8%EF%BC%81%E3%83%88%E3%83%BC%E3%83%81%E4%BD%9C%E6%88%A6%EF%BC%81/E3"}], "evidenceKind": "list-item", "context": "過去の入手方法"}, {"types": ["event", "exchange"], "availability": "historical", "rawText": "2024年 早春イベント『発動！竜巻作戦』E-4 甲(★+6)・乙(★+3)作戦突破選択報酬", "links": [{"text": "発動！竜巻作戦", "href": "https://wikiwiki.jp/kancolle/%E7%99%BA%E5%8B%95%EF%BC%81%E7%AB%9C%E5%B7%BB%E4%BD%9C%E6%88%A6"}, {"text": "E-4", "href": "https://wikiwiki.jp/kancolle/%E7%99%BA%E5%8B%95%EF%BC%81%E7%AB%9C%E5%B7%BB%E4%BD%9C%E6%88%A6/E2"}], "evidenceKind": "list-item", "context": "過去の入手方法"}], "methodCount": 14, "unclassifiedEvidenceCount": 0, "issueCount": 0, "accepted": true, "coverageStatus": "parsed", "schemaVersion": 3, "resolvedShipIds": [397, 544], "resolvedQuestKeys": [], "referenceIssueCount": 0, "referenceSchemaVersion": 2, "rawEvidence": {"cacheKey": "wikiwiki.jp/kancolle/F4U-4.html", "rawPath": "data/raw_data/site_cache/wikiwiki.jp/kancolle/F4U-4.html", "contentSha256": "8d99fad520f6bf4fa9f445236c33d391fe2eaabd8529a3f9aa2b72c8c7b05b2c", "fetchedAt": 1783246906, "validatedAt": 1783246906, "acquisitionSource": "external-browser-session-crawl"}, "fetchAttempts": [{"candidateSource": "raw-cache", "status": "ok", "url": "https://wikiwiki.jp/kancolle/F4U-4", "cachePath": "w