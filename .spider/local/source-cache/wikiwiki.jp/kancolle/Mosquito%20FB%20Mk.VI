<style>
/* 1 */
@media (max-width: 500px) {
    body {
        margin-bottom: 129px !important;
        transition: margin-bottom 0.4s ease-in-out;
    }
    body:has(#div-gpt-ad-1563441919648-0 iframe[height="50"]) {
        margin-bottom: 79px !important;
    }
}

/* 2 */
#overlay-anchor-wrapper {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    width: 100%;
    z-index: 99998;
    pointer-events: none;
    transform: translateY(100%);
    transition: transform 0.4s ease-in-out 10s;
}

body:has(#div-gpt-ad-1563441919648-0 iframe) #overlay-anchor-wrapper {
    transform: translateY(0);
    transition: transform 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.6s;
}

/* 3 */
#pc-overlay-ad-parent-container {
    contain: layout style;
    content-visibility: auto;

    width: 100%;
    background-color: var(--h2-background-color, #ffffff) !important;
    padding-top: 5px;
    padding-bottom: env(safe-area-inset-bottom, 0px);
    box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.1);
    pointer-events: auto;

    max-height: 105px;
    height: auto;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: visible !important;
}

#pc-overlay-ad-parent-container:has(iframe[height="50"]) {
    max-height: 60px;
}

/* 4 */
#pc-overlay-ad-close-button {
    position: absolute;
    top: -24px;
    right: 12px;
    width: 38px; height: 24px;
    background-color: var(--h2-background-color, #ffffff) !important;
    border-radius: 8px 8px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 99999;
    cursor: pointer;
    pointer-events: auto;
    opacity: 0;
    transform: translateY(5px);
    transition: opacity 0.6s ease-out 10s, transform 0.6s ease-out 10s;
}

body:has(#div-gpt-ad-1563441919648-0 iframe) #pc-overlay-ad-close-button {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease-out 1.8s, transform 0.6s ease-out 1.8s;
}

#pc-overlay-ad-close-button svg {
    width: 14px; height: 14px;
    fill: var(--h2-text-color, #666666) !important;
}

/* 5 */
#ad-close-trigger { display: none; }

#ad-close-trigger:checked ~ #overlay-anchor-wrapper {
    transform: translateY(100%) !important;
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.4, 0, 1, 1), opacity 0.4s cubic-bezier(0.4, 0, 1, 1) !important;
    pointer-events: none;
}

body:has(#ad-close-trigger:checked) {
    margin-bottom: 0 !important;
}

/* 6 */
.overlay-ad-container { 
    display: flex; justify-content: center; align-items: center; 
    min-height: 50px; position: relative; 
}
.overlay-ad-container::before { 
    content: ""; position: absolute; width: 320px; height: 100%; 
    border-radius: 4px; z-index: 0;
    animation: quietPulse 3s infinite; 
}
@keyframes quietPulse { 0%, 100% { background-color: transparent; } 50% { background-color: rgba(0, 0, 0, 0.04); } }

#div-gpt-ad-1563441919648-0 { position: relative; z-index: 1; display: flex; justify-content: center; width: 100%; }
#div-gpt-ad-1563441919648-0 iframe {
    animation: fadeInQuick 0.5s ease-in-out 0.2s both !important;
    background: var(--h2-background-color, #ffffff);
}
@keyframes fadeInQuick { from { opacity: 0; } to { opacity: 1; } }
</style>

