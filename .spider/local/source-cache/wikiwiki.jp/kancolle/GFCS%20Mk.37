                                        <h3 id="h3_content_99_0">サイト内検索</h3>
<form action="/kancolle/::cmd/lookup?refer=%E5%8F%8D%E6%92%83%EF%BC%81%E7%AC%AC%E4%B8%89%E5%8D%81%E4%B8%80%E6%88%A6%E9%9A%8A%E3%81%AE%E6%88%A6%E3%81%84%2FE1" method="post">
 <div>
  <input type="hidden" name="inter" value="サイト内検索(by Google)">
